---
import Mandelbulb from '../components/Mandelbulb.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Realtime fractal art playground built with Astro + Three.js. Explore multiple signed-distance fractals with interactive controls and adaptive quality rendering."
    />
    <title>Fractal Art | Realtime Fractal Lab</title>
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        overflow: hidden;
        width: 100%;
        height: 100%;
        background: #04060b;
      }
    </style>
  </head>
  <body>
    <Mandelbulb />
  </body>
</html>
